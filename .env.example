# ── AI Provider (choose one, or configure via Admin UI) ───────────────────────

# Option A: Anthropic Claude (native)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Option B: Any OpenAI-compatible API (OpenAI / DeepSeek / Qwen / Ollama / etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o

# Both fallback to DB-configured AI providers (set via Admin UI)

# Optional: Knowledge retrieval enhancement (SiliconFlow embedding + rerank)
# KB_USE_SILICONFLOW=true
# SILICONFLOW_API_KEY=sk-...
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_EMBED_MODEL=BAAI/bge-large-zh-v1.5
# SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# SILICONFLOW_RERANK_INSTRUCTION=Please rerank the documents based on the query.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Admin ─────────────────────────────────────────────────────────────────────
# Access admin at /admin with this key
ADMIN_KEY=admin

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/history-loong.db

# ── Plugins (comma-separated plugin names in backend/plugins/) ────────────────
ENABLED_PLUGINS=
